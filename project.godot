; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Launcher"
run/main_scene="uid://b2i46equav5t5"
config/features=PackedStringArray("4.6", "Mobile")
run/max_fps=60
boot_splash/bg_color=Color(0.14117648, 0.14117648, 0.14117648, 0)
boot_splash/show_image=false
boot_splash/stretch_mode=0
boot_splash/use_filter=false

[audio]

driver/driver="Pipewire"

[autoload]

Shitfart="*uid://ccok1vy83yc8a"
RmDir="*uid://e5vmglpqwr42"

[compression]

formats/zstd/compression_level=9
formats/zlib/compression_level=9
formats/gzip/compression_level=9

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=3
window/size/borderless=true
window/frame_pacing/android/swappy_mode=0
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_width"
window/handheld/orientation=4

[editor]

import/atlas_max_width=128

[editor_plugins]

enabled=PackedStringArray("res://addons/remove_directory/plugin.cfg")

[gui]

fonts/dynamic_fonts/use_oversampling=false
theme/default_font_antialiasing=0
theme/default_font_hinting=0
theme/default_font_subpixel_positioning=0

[input]

shift={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194325,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

common/physics_interpolation=true

[rendering]

occlusion_culling/bvh_build_quality=0
textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
textures/webp_compression/compression_method=4
textures/webp_compression/lossless_compression_factor=100.0
lights_and_shadows/directional_shadow/size=256
lights_and_shadows/directional_shadow/size.mobile=256
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=0
2d/shadow_atlas/size=128
reflections/sky_reflections/roughness_layers=1
reflections/sky_reflections/texture_array_reflections=false
global_illumination/gi/use_half_resolution=true
textures/default_filters/anisotropic_filtering_level=0
camera/depth_of_field/depth_of_field_bokeh_shape=0
camera/depth_of_field/depth_of_field_bokeh_quality=0
environment/ssao/quality=0
environment/ssao/half_size=false
environment/ssil/quality=0
environment/ssil/half_size=false
anti_aliasing/quality/msaa_2d=1
anti_aliasing/quality/use_debanding=true
textures/decals/filter=0
textures/light_projectors/filter=0
occlusion_culling/occlusion_rays_per_thread=8
environment/glow/upscale_mode=0
global_illumination/sdfgi/probe_ray_count=0
global_illumination/sdfgi/frames_to_converge=0
global_illumination/sdfgi/frames_to_update_lights=4
environment/defaults/default_clear_color=Color(0, 0, 0, 1)
textures/basis_universal/zstd_supercompression_level=9
occlusion_culling/use_occlusion_culling=true
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true
lights_and_shadows/positional_shadow/atlas_size=256
lights_and_shadows/positional_shadow/atlas_size.mobile=256
lights_and_shadows/positional_shadow/atlas_quadrant_0_subdiv=0
lights_and_shadows/positional_shadow/atlas_quadrant_1_subdiv=0
